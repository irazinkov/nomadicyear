---
import BaseHead from "../components/BaseHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_TITLE } from "../consts";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const navLinks = [
  { href: "/south-america-expense-report-in-korean", label: "Our Korean Blog" },
  { href: "/video", label: "Video" },
  { href: "/image-gallery", label: "Image Gallery" },
  { href: "/map", label: "Route" },
  { href: "/preparation", label: "Preparation" },
  { href: "/travel-tips", label: "Travel Tips" },
  { href: "/sponsors-and-credits", label: "People Who Helped" },
  { href: "/about", label: "About Us" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} noindex={noindex} />
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900 dark:bg-slate-900 dark:text-gray-100"
  >
    <div
      class="mx-auto flex min-h-screen max-w-3xl flex-col px-4 sm:px-6 lg:px-8"
    >
      <header class="py-8">
        <div class="mb-4 flex items-center justify-between">
          <a
            href="/"
            class="text-xl font-semibold tracking-tight text-gray-900 dark:text-white"
          >
            {SITE_TITLE}
          </a>
          <div class="flex items-center gap-2 text-sm">
            <a
              href="/blog/"
              class="rounded px-2 py-1 text-gray-700 transition hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
            >
              Blog
            </a>
            <a
              href="/destinations/"
              class="rounded px-2 py-1 text-gray-700 transition hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
            >
              Destinations
            </a>
            <ThemeToggle />
          </div>
        </div>
        <nav class="overflow-x-auto pb-1">
          <div
            class="flex min-w-max items-center gap-1 text-xs font-semibold uppercase tracking-wide sm:gap-3 sm:text-sm"
          >
            {
              navLinks.map((link) => {
                const normalizedHref = link.href.replace(/\/+$/, "") || "/";
                const isActive = pathname === normalizedHref;
                return (
                  <a
                    href={`${normalizedHref}/`}
                    class:list={[
                      "rounded px-2 py-1 transition",
                      isActive
                        ? "text-teal-800 dark:text-teal-300"
                        : "text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white",
                    ]}
                  >
                    {link.label}
                  </a>
                );
              })
            }
          </div>
        </nav>
      </header>

      <main class="flex-1 pb-16">
        <slot />
      </main>

      <footer
        class="border-t border-gray-200 py-8 text-sm text-gray-600 dark:border-gray-800 dark:text-gray-400"
      >
        <p>&copy; {new Date().getFullYear()} {SITE_TITLE}</p>
      </footer>
    </div>
  </body>
</html>
