---
import BaseHead from "../components/BaseHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_TITLE } from "../consts";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const pathname = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/destinations", label: "Destinations" },
  { href: "/about", label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} noindex={noindex} />
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900 dark:bg-slate-900 dark:text-gray-100"
  >
    <div
      class="mx-auto flex min-h-screen max-w-3xl flex-col px-4 sm:px-6 lg:px-8"
    >
      <header class="py-8">
        <nav class="flex items-center justify-between">
          <a
            href="/"
            class="text-xl font-semibold tracking-tight text-gray-900 dark:text-white"
          >
            {SITE_TITLE}
          </a>
          <div class="flex items-center gap-2 text-sm sm:gap-5">
            {
              navLinks.map((link) => {
                const isActive = pathname === link.href;
                return (
                  <a
                    href={link.href}
                    class:list={[
                      "rounded px-2 py-1 transition",
                      isActive
                        ? "text-teal-800 dark:text-teal-300"
                        : "text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white",
                    ]}
                  >
                    {link.label}
                  </a>
                );
              })
            }
            <ThemeToggle />
          </div>
        </nav>
      </header>

      <main class="flex-1 pb-16">
        <slot />
      </main>

      <footer
        class="border-t border-gray-200 py-8 text-sm text-gray-600 dark:border-gray-800 dark:text-gray-400"
      >
        <p>&copy; {new Date().getFullYear()} {SITE_TITLE}</p>
      </footer>
    </div>
  </body>
</html>
