---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { getUploadResponsiveSources } from "../utils/uploadImage";
import { formatTaxonomyLabel } from "../utils/posts";
import Layout from "./Layout.astro";

type Props = CollectionEntry<"posts">["data"] & {
  readingTimeMinutes?: number;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  country,
  categories = [],
  tags = [],
  readingTimeMinutes = 1,
} = Astro.props;

const hasHeroImage = Boolean(heroImage);
const localHeroImage = typeof heroImage === "string" ? undefined : heroImage;
const remoteHeroImage = typeof heroImage === "string" ? heroImage : undefined;
const remoteHeroResponsiveSources =
  remoteHeroImage && remoteHeroImage.startsWith("/uploads/")
    ? getUploadResponsiveSources(remoteHeroImage)
    : null;
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-3xl" data-lightbox-root>
    <header class="space-y-4 pb-8">
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white"
      >
        {title}
      </h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        <FormattedDate date={pubDate} /> • {readingTimeMinutes} min read
      </p>
      {
        updatedDate && (
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Last updated <FormattedDate date={updatedDate} />
          </p>
        )
      }
      <div class="space-y-2">
        {
          country && (
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Country:{" "}
              <a href={`/country/${country}/`}>
                {formatTaxonomyLabel(country)}
              </a>
            </p>
          )
        }
        {
          categories.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {categories.map((category) => (
                <li>
                  <a
                    href={`/category/${category}/`}
                    class="rounded-full bg-gray-200 px-3 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-200"
                  >
                    {formatTaxonomyLabel(category)}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        {
          tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li>
                  <a
                    href={`/tag/${tag}/`}
                    class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700 dark:bg-gray-900 dark:text-gray-200"
                  >
                    {formatTaxonomyLabel(tag)}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    {
      hasHeroImage && (
        <div class="mb-10">
          {localHeroImage ? (
            <Image
              src={localHeroImage}
              width={1200}
              format="webp"
              alt={heroImageAlt ?? title}
              class="w-full rounded-lg shadow-md"
            />
          ) : (
            <img
              src={remoteHeroResponsiveSources?.src ?? remoteHeroImage}
              alt={heroImageAlt ?? title}
              class="w-full rounded-lg shadow-md"
              srcset={remoteHeroResponsiveSources?.srcset}
              sizes={remoteHeroResponsiveSources?.sizes}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          )}
        </div>
      )
    }

    <div class="ny-prose-readable prose prose-lg mx-auto max-w-none prose-img:w-full prose-img:max-w-full prose-img:rounded-xl prose-img:shadow-md dark:prose-invert">
      <slot />
    </div>
  </article>
</Layout>
