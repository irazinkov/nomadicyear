---
import FormattedDate from "./FormattedDate.astro";
import { formatTaxonomyLabel, getPostUrl, type PostEntry } from "../utils/posts";
import { getUploadResponsiveSources } from "../utils/uploadImage";

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const summary = post.data.excerpt || post.data.description;
const primaryCategories = post.data.categories.slice(0, 2);
const heroImage = post.data.heroImage;
const heroImageAlt = post.data.heroImageAlt || `${post.data.title} cover image`;
const heroResponsiveSources =
  heroImage && heroImage.startsWith("/uploads/")
    ? getUploadResponsiveSources(heroImage)
    : null;
---

<article
  class="group flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-slate-950"
>
  {
    heroImage && (
      <a href={getPostUrl(post)} class="-mx-5 -mt-5 mb-4 block overflow-hidden">
        <img
          src={heroResponsiveSources?.src ?? heroImage}
          alt={heroImageAlt}
          class="aspect-[16/10] h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          srcset={heroResponsiveSources?.srcset}
          sizes={heroResponsiveSources?.sizes ?? "(max-width: 1024px) 100vw, 33vw"}
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }

  <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
    <FormattedDate date={post.data.pubDate} />
  </p>

  <h2 class="mt-2 text-xl font-semibold leading-tight text-gray-900 dark:text-gray-100">
    <a href={getPostUrl(post)} class="hover:text-accent-500">
      {post.data.title}
    </a>
  </h2>

  {
    summary && (
      <p class="mt-3 flex-1 text-sm text-gray-600 dark:text-gray-300">{summary}</p>
    )
  }

  <div class="mt-4 flex flex-wrap gap-2">
    {
      post.data.country && (
        <span class="rounded-full bg-teal-50 px-2.5 py-1 text-xs font-medium text-teal-800 dark:bg-teal-950 dark:text-teal-200">
          {formatTaxonomyLabel(post.data.country)}
        </span>
      )
    }
    {
      primaryCategories.map((category) => (
        <span class="rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700 dark:bg-gray-900 dark:text-gray-300">
          {formatTaxonomyLabel(category)}
        </span>
      ))
    }
  </div>
</article>
