<div
  id="ny-lightbox"
  class="ny-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  hidden
>
  <div class="ny-lightbox__backdrop" data-ny-lightbox-close></div>
  <figure class="ny-lightbox__figure">
    <img
      id="ny-lightbox-image"
      class="ny-lightbox__image"
      src=""
      alt="Expanded image"
      decoding="async"
    />
    <figcaption id="ny-lightbox-caption" class="ny-lightbox__caption"></figcaption>
    <div class="ny-lightbox__toolbar">
      <button
        id="ny-lightbox-prev"
        type="button"
        class="ny-lightbox__button"
        aria-label="Show previous image"
      >
        Prev
      </button>
      <span
        id="ny-lightbox-counter"
        class="ny-lightbox__counter"
        aria-live="polite"
      ></span>
      <a
        id="ny-lightbox-original"
        class="ny-lightbox__link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open Full Resolution
      </a>
      <button
        id="ny-lightbox-next"
        type="button"
        class="ny-lightbox__button"
        aria-label="Show next image"
      >
        Next
      </button>
      <button
        id="ny-lightbox-close"
        type="button"
        class="ny-lightbox__button"
        aria-label="Close image viewer"
        data-ny-lightbox-close
      >
        Close
      </button>
    </div>
  </figure>
</div>

<script is:inline>
  (() => {
    if (typeof window === "undefined") return;

    const imageExtensionPattern =
      /\.(avif|webp|jpe?g|png|gif|bmp|svg)(?:[?#]|$)/i;

    const lightbox = document.getElementById("ny-lightbox");
    const lightboxImage = document.getElementById("ny-lightbox-image");
    const lightboxCaption = document.getElementById("ny-lightbox-caption");
    const lightboxCounter = document.getElementById("ny-lightbox-counter");
    const lightboxOriginal = document.getElementById("ny-lightbox-original");
    const prevButton = document.getElementById("ny-lightbox-prev");
    const nextButton = document.getElementById("ny-lightbox-next");
    const closeButton = document.getElementById("ny-lightbox-close");

    if (
      !lightbox ||
      !(lightboxImage instanceof HTMLImageElement) ||
      !lightboxCaption ||
      !lightboxCounter ||
      !(lightboxOriginal instanceof HTMLAnchorElement) ||
      !(prevButton instanceof HTMLButtonElement) ||
      !(nextButton instanceof HTMLButtonElement) ||
      !(closeButton instanceof HTMLButtonElement)
    ) {
      return;
    }

    const roots = [...document.querySelectorAll("[data-lightbox-root]")];
    if (roots.length === 0) return;

    const items = [];
    let currentIndex = 0;
    let active = false;
    let previousBodyOverflow = "";

    const toAbsoluteUrl = (value) => {
      try {
        return new URL(value, window.location.href).toString();
      } catch {
        return value;
      }
    };

    const isImageLikeHref = (href) => {
      return href.startsWith("/uploads/") || imageExtensionPattern.test(href);
    };

    const getFullResolutionUrl = (image) => {
      const anchor = image.closest("a[href]");
      if (anchor instanceof HTMLAnchorElement) {
        const href = anchor.getAttribute("href") || "";
        if (isImageLikeHref(href)) {
          return toAbsoluteUrl(href);
        }
      }
      return toAbsoluteUrl(image.currentSrc || image.src);
    };

    const render = () => {
      const item = items[currentIndex];
      if (!item) return;

      lightboxImage.src = item.previewUrl;
      lightboxImage.alt = item.altText;
      lightboxCaption.textContent = item.altText || " ";
      lightboxOriginal.href = item.fullUrl;
      lightboxCounter.textContent = `${currentIndex + 1} / ${items.length}`;

      const hasMultiple = items.length > 1;
      prevButton.disabled = !hasMultiple;
      nextButton.disabled = !hasMultiple;
    };

    const open = (index) => {
      currentIndex = index;
      render();
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = "hidden";
      lightbox.hidden = false;
      active = true;
      closeButton.focus();
    };

    const close = () => {
      lightbox.hidden = true;
      lightboxImage.src = "";
      active = false;
      document.body.style.overflow = previousBodyOverflow;
    };

    const showPrevious = () => {
      if (items.length < 2) return;
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      render();
    };

    const showNext = () => {
      if (items.length < 2) return;
      currentIndex = (currentIndex + 1) % items.length;
      render();
    };

    roots.forEach((root) => {
      const images = [...root.querySelectorAll("img")];
      images.forEach((image) => {
        if (!(image instanceof HTMLImageElement)) return;
        if (image.dataset.lightbox === "off") return;
        const anchor = image.closest("a[href]");
        if (anchor instanceof HTMLAnchorElement) {
          const href = anchor.getAttribute("href") || "";
          if (!isImageLikeHref(href)) return;
        }

        const index = items.length;
        image.dataset.lightboxIndex = String(index);
        image.classList.add("ny-lightbox-clickable");

        const previewUrl = toAbsoluteUrl(image.currentSrc || image.src);
        const fullUrl = getFullResolutionUrl(image);
        const altText = image.getAttribute("alt") || "Image";

        items.push({
          previewUrl,
          fullUrl,
          altText,
        });
      });

      root.addEventListener("click", (event) => {
        if (!(event.target instanceof HTMLElement)) return;
        const image = event.target.closest("img[data-lightbox-index]");
        if (!(image instanceof HTMLImageElement)) return;
        if (!root.contains(image)) return;

        if (event instanceof MouseEvent) {
          if (event.button !== 0) return;
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
            return;
          }
        }

        const index = Number(image.dataset.lightboxIndex);
        if (Number.isNaN(index)) return;

        event.preventDefault();
        open(index);
      });
    });

    if (items.length === 0) return;

    prevButton.addEventListener("click", showPrevious);
    nextButton.addEventListener("click", showNext);
    closeButton.addEventListener("click", close);

    lightbox.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches("[data-ny-lightbox-close]")) {
        close();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!active) return;
      if (event.key === "Escape") close();
      if (event.key === "ArrowLeft") showPrevious();
      if (event.key === "ArrowRight") showNext();
    });
  })();
</script>
