---
import { getCollection } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import PostArchiveCard from "../../../components/PostArchiveCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../../consts";
import Layout from "../../../layouts/Layout.astro";
import { sortPostsByDateDesc } from "../../../utils/posts";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("posts"))
    .filter((post) => !post.data.draft)
    .sort(sortPostsByDateDesc);
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const page = Astro.props.page as Page<CollectionEntry<"posts">>;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
---

<Layout
  title={`Blog Page ${currentPage} | ${SITE_TITLE}`}
  description={SITE_DESCRIPTION}
>
  <section class="space-y-6">
    <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">
      Blog Archive
    </h1>
    <p class="text-gray-600 dark:text-gray-400">
      Page {currentPage} of {totalPages}
    </p>
    <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        page.data.map((post) => (
          <li class="h-full">
            <PostArchiveCard post={post} />
          </li>
        ))
      }
    </ul>
    <nav class="flex items-center justify-between pt-4" aria-label="Pagination">
      {
        page.url.prev ? (
          <a
            href={page.url.prev}
            class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium dark:border-gray-700"
          >
            ← Newer Posts
          </a>
        ) : (
          <span />
        )
      }
      {
        page.url.next && (
          <a
            href={page.url.next}
            class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium dark:border-gray-700"
          >
            Older Posts →
          </a>
        )
      }
    </nav>
  </section>
</Layout>
