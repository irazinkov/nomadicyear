---
import { getCollection } from "astro:content";
import PostArchiveCard from "../../components/PostArchiveCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import { sortPostsByDateDesc } from "../../utils/posts";

const PAGE_SIZE = 10;

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort(sortPostsByDateDesc);

const firstPagePosts = posts.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
---

<Layout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <section class="space-y-6">
    <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">Blog</h1>
    <p class="text-gray-600 dark:text-gray-400">
      Long-form travel posts from the road.
    </p>
    <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        firstPagePosts.map((post) => (
          <li class="h-full">
            <PostArchiveCard post={post} />
          </li>
        ))
      }
    </ul>
    {
      totalPages > 1 && (
        <div class="flex justify-end pt-4">
          <a
            href="/blog/page/2/"
            class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium dark:border-gray-700"
          >
            Older Posts →
          </a>
        </div>
      )
    }
  </section>
</Layout>
