---
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import FormattedDate from "../components/FormattedDate.astro";
import Layout from "../layouts/Layout.astro";
import { getPostUrl, sortPostsByDateDesc } from "../utils/posts";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort(sortPostsByDateDesc);

const postsByYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = String(post.data.pubDate.getFullYear());
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="space-y-8">
    <div class="space-y-2">
      <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">
        Travel Archive
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        Ten years of notes, routes, border crossings, and long train rides.
      </p>
    </div>

    {
      years.map((year) => (
        <section class="space-y-4" aria-label={`Posts from ${year}`}>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
            {year}
          </h2>
          <ul class="space-y-2">
            {postsByYear[year].map((post) => (
              <li>
                <a
                  href={getPostUrl(post)}
                  class="flex items-baseline gap-4 rounded px-2 py-1 transition hover:bg-gray-100 dark:hover:bg-gray-800"
                >
                  <span class="w-16 shrink-0 text-sm text-gray-500 dark:text-gray-400">
                    <FormattedDate
                      date={post.data.pubDate}
                      includeYear={false}
                    />
                  </span>
                  <span class="font-semibold text-gray-900 dark:text-gray-100">
                    {post.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
    <div class="pt-2">
      <a href="/blog/" class="text-sm font-medium">Browse full archive →</a>
    </div>
  </section>
</Layout>
