---
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import {
  formatTaxonomyLabel,
  getPostUrl,
  sortPostsByDateDesc,
} from "../../utils/posts";

export async function getStaticPaths() {
  const posts = (await getCollection("posts"))
    .filter((post) => !post.data.draft)
    .sort(sortPostsByDateDesc);

  const slugs = new Set<string>();
  for (const post of posts) {
    for (const category of post.data.categories) {
      slugs.add(category);
    }
  }

  return [...slugs].map((taxonomySlug) => ({ params: { slug: taxonomySlug } }));
}

const slug = String(Astro.params.slug ?? "");
const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort(sortPostsByDateDesc);

const posts = allPosts.filter((post) => post.data.categories.includes(slug));
const label = formatTaxonomyLabel(slug);
---

<Layout
  title={`Category: ${label} | ${SITE_TITLE}`}
  description={`Posts in category ${label}.`}
>
  <section class="space-y-6">
    <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">
      Category: {label}
    </h1>
    <p class="text-gray-600 dark:text-gray-400">
      {posts.length} post{posts.length === 1 ? "" : "s"}
    </p>
    <ul class="space-y-4">
      {
        posts.map((post) => (
          <li>
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-slate-950">
              <p class="mb-2 text-sm text-gray-500 dark:text-gray-400">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
                <a href={getPostUrl(post)}>{post.data.title}</a>
              </h2>
              <p class="mt-2 text-gray-600 dark:text-gray-300">
                {post.data.excerpt || post.data.description}
              </p>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
