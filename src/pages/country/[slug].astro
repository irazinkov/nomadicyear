---
import { getCollection } from "astro:content";
import PostArchiveCard from "../../components/PostArchiveCard.astro";
import { SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import { formatTaxonomyLabel, sortPostsByDateDesc } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = (await getCollection("posts"))
    .filter((post) => !post.data.draft)
    .sort(sortPostsByDateDesc);

  const slugs = new Set<string>(
    posts
      .map((post) => post.data.country)
      .filter((country): country is string => Boolean(country)),
  );

  return [...slugs].map((taxonomySlug) => ({ params: { slug: taxonomySlug } }));
}

const slug = String(Astro.params.slug ?? "");
const allPosts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort(sortPostsByDateDesc);

const posts = allPosts.filter((post) => post.data.country === slug);
const label = formatTaxonomyLabel(slug);
---

<Layout
  title={`Country: ${label} | ${SITE_TITLE}`}
  description={`Posts from ${label}.`}
>
  <section class="space-y-6">
    <h1 class="text-3xl font-semibold text-gray-900 dark:text-white">
      Country: {label}
    </h1>
    <p class="text-gray-600 dark:text-gray-400">
      {posts.length} post{posts.length === 1 ? "" : "s"}
    </p>
    {
      posts.length > 0 ? (
        <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li class="h-full">
              <PostArchiveCard post={post} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="rounded-lg border border-dashed border-gray-300 bg-white p-4 text-gray-600 dark:border-gray-700 dark:bg-slate-950 dark:text-gray-300">
          No posts found for this country yet.
        </p>
      )
    }
  </section>
</Layout>
