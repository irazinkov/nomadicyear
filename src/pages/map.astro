---
import { readFileSync } from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { getPostSlug } from "../utils/posts";

interface MapStep {
  mapOrder: number;
  slug: string;
  title: string;
  mapTitle: string;
  lat: number;
  lng: number;
  transport: "drive" | "boat" | "flight";
  url: string;
  heroImage: string | null;
  heroImageAlt: string | null;
}

const postEntries = (await getCollection("posts")).filter((entry) => {
  return !entry.data.draft && entry.data.status !== "draft";
});

const rawMapSteps = postEntries.flatMap((entry) => {
  const data = entry.data;
  const baseDate = new Date(data.pubDate).getTime();
  const sourceDate = Number.isFinite(baseDate) ? baseDate : 0;
  const resolvedSlug = getPostSlug(entry);
  const baseStep = {
    slug: resolvedSlug,
    title: data.title,
    url: `/blog/${resolvedSlug}/`,
    heroImage: data.heroImage ?? null,
    heroImageAlt: data.heroImageAlt ?? null,
  };

  if (Array.isArray(data.routeWaypoints) && data.routeWaypoints.length > 0) {
    return data.routeWaypoints.map((waypoint, waypointIndex) => ({
      ...baseStep,
      mapTitle: waypoint.label || data.mapTitle || data.title,
      lat: waypoint.lat,
      lng: waypoint.lng,
      transport: waypoint.transport || data.transport || "drive",
      heroImage: waypoint.image || baseStep.heroImage,
      heroImageAlt: waypoint.imageAlt || baseStep.heroImageAlt,
      sourceDate,
      sourceWaypointIndex: waypointIndex,
    }));
  }

  if (typeof data.lat === "number" && typeof data.lng === "number") {
    return [
      {
        ...baseStep,
        mapTitle: data.mapTitle || data.title,
        lat: data.lat,
        lng: data.lng,
        transport: data.transport || "drive",
        sourceDate,
        sourceWaypointIndex: 0,
      },
    ];
  }

  return [];
});

const mapSteps: MapStep[] = rawMapSteps
  .slice()
  .sort((a, b) => {
    if (a.sourceDate !== b.sourceDate) {
      return a.sourceDate - b.sourceDate;
    }
    if (a.sourceWaypointIndex !== b.sourceWaypointIndex) {
      return a.sourceWaypointIndex - b.sourceWaypointIndex;
    }
    return a.slug.localeCompare(b.slug);
  })
  .map(({ sourceDate: _sourceDate, sourceWaypointIndex: _sourceWaypointIndex, ...step }, index) => ({
    ...step,
    mapOrder: index + 1,
  }));
let routeGeoJson: Record<string, unknown> | null = null;
try {
  const routePath = path.join(process.cwd(), "src", "data", "route.geojson");
  routeGeoJson = JSON.parse(readFileSync(routePath, "utf8"));
} catch {
  routeGeoJson = null;
}
let routeTraceGeoJson: Record<string, unknown> | null = null;
try {
  const tracePath = path.join(process.cwd(), "src", "data", "route-trace.geojson");
  routeTraceGeoJson = JSON.parse(readFileSync(tracePath, "utf8"));
} catch {
  routeTraceGeoJson = null;
}
const mapboxToken = (import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "").trim();
const hasMapboxToken = mapboxToken.length > 0;
const mobileMenuLinks = [
  { href: "/blog", label: "Blog" },
  { href: "/map", label: "Route" },
  {
    href: "https://m.blog.naver.com/nomadicyear",
    label: "Our Korean Blog",
  },
  { href: "/destinations", label: "Destinations" },
  { href: "/video", label: "Video" },
  { href: "/image-gallery", label: "Image Gallery" },
  { href: "/preparation", label: "Preparation" },
  { href: "/travel-tips", label: "Travel Tips" },
  { href: "/sponsors-and-credits", label: "People Who Helped Us" },
  { href: "/about", label: "About Us" },
];
---

<Layout
  title="Route"
  description="Interactive route map with post markers across our world trip."
  bodyClass="ny-route-mobile-fullscreen"
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css"
    />
    {
      hasMapboxToken ? (
        <script
          is:inline
          src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"
        ></script>
      ) : null
    }
  </Fragment>

  <section class="ny-route-page" data-mapbox-token={mapboxToken}>
    <header class="ny-route-page__header">
      <p class="ny-route-page__kicker">Route Story</p>
      <h1>Follow Our Exact Route</h1>
      <p>
        Tap a marker or select a stop to jump around the trip and open the
        related blog post.
      </p>
    </header>

    <div class="ny-route-layout">
      <aside class="ny-route-steps" aria-label="Trip stops">
        <ol class="ny-route-steps__list">
          {
            mapSteps.map((step, index) => (
              <li class="ny-route-step">
                <button
                  type="button"
                  class="ny-route-step__focus"
                  data-route-step={index}
                >
                  <span class="ny-route-step__meta">
                    Stop {step.mapOrder} • {step.transport}
                  </span>
                  <strong>{step.mapTitle || step.title}</strong>
                  <span class="ny-route-step__title">{step.title}</span>
                </button>
                <a class="ny-route-step__read" href={step.url}>
                  Read post
                </a>
              </li>
            ))
          }
        </ol>
      </aside>

      <div class="ny-route-map-wrap">
        <details class="ny-mobile-menu ny-route-mobile-menu sm:hidden">
          <summary class="ny-mobile-menu__summary">
            <span class="ny-mobile-menu__label">Route</span>
            <span class="ny-mobile-menu__icon" aria-hidden="true">
              <span class="ny-mobile-menu__line ny-mobile-menu__line--top"></span>
              <span class="ny-mobile-menu__line ny-mobile-menu__line--middle"></span>
              <span class="ny-mobile-menu__line ny-mobile-menu__line--bottom"></span>
            </span>
          </summary>
          <button
            type="button"
            class="ny-mobile-menu__backdrop"
            aria-label="Close navigation menu"
          ></button>
          <nav class="ny-mobile-menu__panel" aria-label="Mobile site menu">
            <ul class="ny-mobile-menu__list">
              {
                mobileMenuLinks.map((link) => {
                  const isExternal = /^https?:\/\//i.test(link.href);
                  const normalizedHref = isExternal
                    ? link.href
                    : link.href.replace(/\/+$/, "") || "/";
                  const isActive = !isExternal && normalizedHref === "/map";
                  return (
                    <li>
                      <a
                        href={isExternal ? normalizedHref : `${normalizedHref}/`}
                        target={isExternal ? "_blank" : undefined}
                        rel={isExternal ? "noopener noreferrer" : undefined}
                        class:list={[
                          "ny-mobile-menu__link",
                          isActive ? "is-active" : "",
                        ]}
                      >
                        {link.label}
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </nav>
        </details>
        <div id="ny-route-map" class="ny-route-map" aria-label="Route map"></div>
        <div class="ny-route-legend">
          <span><i class="legend-dot legend-dot--drive"></i>Drive</span>
          <span><i class="legend-dot legend-dot--boat"></i>Boat</span>
          <span><i class="legend-dot legend-dot--flight"></i>Flight</span>
        </div>
        {
          !hasMapboxToken ? (
            <p class="ny-route-token-note">
              Set <code>PUBLIC_MAPBOX_TOKEN</code> to enable the interactive
              map.
            </p>
          ) : null
        }
      </div>
    </div>
  </section>

  <script define:vars={{ mapSteps, routeGeoJson, routeTraceGeoJson }}>
    (() => {
      const page = document.querySelector(".ny-route-page");
      const mapNode = document.getElementById("ny-route-map");
      if (!page || !mapNode) return;

      const token = page.dataset.mapboxToken || "";
      const steps = Array.isArray(mapSteps) ? mapSteps : [];
      const traceData = routeTraceGeoJson &&
        routeTraceGeoJson.type === "FeatureCollection" &&
        Array.isArray(routeTraceGeoJson.features) &&
        routeTraceGeoJson.features.length > 0
        ? routeTraceGeoJson
        : null;
      const ROUTE_MATCH_MAX_ANCHOR_DISTANCE_KM = 220;
      const toRadiansForRoute = (value) => (value * Math.PI) / 180;
      const haversineKmForRoute = (fromLng, fromLat, toLng, toLat) => {
        const earthRadiusKm = 6371;
        const dLat = toRadiansForRoute(toLat - fromLat);
        const dLng = toRadiansForRoute(toLng - fromLng);
        const lat1 = toRadiansForRoute(fromLat);
        const lat2 = toRadiansForRoute(toLat);
        const sinLat = Math.sin(dLat / 2);
        const sinLng = Math.sin(dLng / 2);
        const a =
          sinLat * sinLat +
          Math.cos(lat1) * Math.cos(lat2) * sinLng * sinLng;
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return earthRadiusKm * c;
      };
      const roundCoordinateForRoute = (value) => Number(value.toFixed(6));

      const buildStraightRouteData = () => ({
        type: "FeatureCollection",
        features: steps
          .map((step, index) => {
            const nextStep = steps[index + 1];
            if (!nextStep) return null;
            return {
              type: "Feature",
              properties: {
                segment: index + 1,
                from: step.mapTitle || step.title,
                to: nextStep.mapTitle || nextStep.title,
                transport: step.transport || "drive",
                source: "fallback-straight",
              },
              geometry: {
                type: "LineString",
                coordinates: [
                  [step.lng, step.lat],
                  [nextStep.lng, nextStep.lat],
                ],
              },
            };
          })
          .filter(Boolean),
      });

      const buildTraceCoordinatePool = () => {
        if (!traceData || !Array.isArray(traceData.features)) return [];
        return traceData.features.flatMap((feature) => {
          const geometry = feature?.geometry;
          if (!geometry) return [];
          if (geometry.type === "LineString") {
            return Array.isArray(geometry.coordinates) ? geometry.coordinates : [];
          }
          if (geometry.type === "MultiLineString") {
            return Array.isArray(geometry.coordinates)
              ? geometry.coordinates.flat()
              : [];
          }
          return [];
        }).filter((coordinate) => {
          return Array.isArray(coordinate) &&
            Number.isFinite(coordinate[0]) &&
            Number.isFinite(coordinate[1]);
        });
      };

      const findNearestTraceIndex = (
        traceCoordinates,
        targetLng,
        targetLat,
        startIndex = 0,
      ) => {
        let bestIndex = -1;
        let bestDistance = Number.POSITIVE_INFINITY;
        for (let index = Math.max(0, startIndex); index < traceCoordinates.length; index += 1) {
          const coordinate = traceCoordinates[index];
          const distance = haversineKmForRoute(
            targetLng,
            targetLat,
            coordinate[0],
            coordinate[1],
          );
          if (distance < bestDistance) {
            bestDistance = distance;
            bestIndex = index;
            if (bestDistance <= 0.05) break;
          }
        }
        return { index: bestIndex, distanceKm: bestDistance };
      };

      const buildTraceMatchedRouteData = () => {
        const traceCoordinates = buildTraceCoordinatePool();
        if (traceCoordinates.length < 2) return null;

        const features = [];
        let searchStart = 0;

        for (let index = 0; index < steps.length - 1; index += 1) {
          const step = steps[index];
          const nextStep = steps[index + 1];
          const transport = step.transport || "drive";

          const straightCoordinates = [
            [step.lng, step.lat],
            [nextStep.lng, nextStep.lat],
          ];

          if (transport !== "drive") {
            features.push({
              type: "Feature",
              properties: {
                segment: index + 1,
                from: step.mapTitle || step.title,
                to: nextStep.mapTitle || nextStep.title,
                transport,
                source: "fallback-straight",
              },
              geometry: {
                type: "LineString",
                coordinates: straightCoordinates,
              },
            });
            continue;
          }

          const startAnchor = findNearestTraceIndex(
            traceCoordinates,
            step.lng,
            step.lat,
            searchStart,
          );
          const endAnchor = findNearestTraceIndex(
            traceCoordinates,
            nextStep.lng,
            nextStep.lat,
            Math.max(searchStart, startAnchor.index),
          );

          const canUseTrace = startAnchor.index >= 0 &&
            endAnchor.index >= 0 &&
            endAnchor.index > startAnchor.index &&
            startAnchor.distanceKm <= ROUTE_MATCH_MAX_ANCHOR_DISTANCE_KM &&
            endAnchor.distanceKm <= ROUTE_MATCH_MAX_ANCHOR_DISTANCE_KM;

          if (!canUseTrace) {
            features.push({
              type: "Feature",
              properties: {
                segment: index + 1,
                from: step.mapTitle || step.title,
                to: nextStep.mapTitle || nextStep.title,
                transport,
                source: "fallback-straight",
              },
              geometry: {
                type: "LineString",
                coordinates: straightCoordinates,
              },
            });
            continue;
          }

          const matchedCoordinates = traceCoordinates
            .slice(startAnchor.index, endAnchor.index + 1)
            .map((coordinate) => [
              roundCoordinateForRoute(coordinate[0]),
              roundCoordinateForRoute(coordinate[1]),
            ]);

          matchedCoordinates[0] = [
            roundCoordinateForRoute(step.lng),
            roundCoordinateForRoute(step.lat),
          ];
          matchedCoordinates[matchedCoordinates.length - 1] = [
            roundCoordinateForRoute(nextStep.lng),
            roundCoordinateForRoute(nextStep.lat),
          ];

          features.push({
            type: "Feature",
            properties: {
              segment: index + 1,
              from: step.mapTitle || step.title,
              to: nextStep.mapTitle || nextStep.title,
              transport,
              source: "trace-matched",
              anchorStartDistanceKm: Number(startAnchor.distanceKm.toFixed(2)),
              anchorEndDistanceKm: Number(endAnchor.distanceKm.toFixed(2)),
            },
            geometry: {
              type: "LineString",
              coordinates: matchedCoordinates,
            },
          });

          searchStart = endAnchor.index;
        }

        return {
          type: "FeatureCollection",
          features,
        };
      };

      const fallbackRouteData = buildTraceMatchedRouteData() || buildStraightRouteData();
      const routeData = routeGeoJson &&
        routeGeoJson.type === "FeatureCollection" &&
        Array.isArray(routeGeoJson.features) &&
        routeGeoJson.features.length > 0 &&
        routeGeoJson.features.length === Math.max(0, steps.length - 1)
        ? routeGeoJson
        : fallbackRouteData;
      const stepButtons = Array.from(document.querySelectorAll("[data-route-step]"));
      const isCoarsePointer = window.matchMedia("(pointer: coarse)").matches;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (!token || typeof window.mapboxgl === "undefined") {
        mapNode.classList.add("ny-route-map--disabled");
        mapNode.innerHTML =
          "<p class='ny-route-map__disabled-copy'>Map preview is ready. Add PUBLIC_MAPBOX_TOKEN to enable Mapbox.</p>";
        return;
      }

      const mapboxgl = window.mapboxgl;
      mapboxgl.accessToken = token;

      const map = new mapboxgl.Map({
        container: mapNode,
        style: "mapbox://styles/mapbox/outdoors-v12",
        center: [90, 37],
        zoom: 1.35,
        projection: "globe",
        attributionControl: false,
      });

      map.addControl(new mapboxgl.AttributionControl({ compact: true }));
      map.addControl(new mapboxgl.NavigationControl(), "top-right");
      map.scrollZoom.enable();

      const bounds = new mapboxgl.LngLatBounds();
      steps.forEach((step) => bounds.extend([step.lng, step.lat]));

      const stepPointData = {
        type: "FeatureCollection",
        features: steps.map((step, index) => ({
          type: "Feature",
          properties: {
            index,
            markerLabel: String(index + 1),
            transport: step.transport || "drive",
          },
          geometry: {
            type: "Point",
            coordinates: [step.lng, step.lat],
          },
        })),
      };

      const popup = new mapboxgl.Popup({
        className: "ny-map-popup-shell",
        closeButton: false,
        closeOnClick: false,
        focusAfterOpen: false,
        offset: 14,
        maxWidth: "160px",
      });
      const pointCircleRadius = [
        "interpolate",
        ["exponential", 1.2],
        ["zoom"],
        1,
        6.8,
        3,
        9.4,
        6,
        13.2,
      ];
      const pointLabelSize = [
        "interpolate",
        ["exponential", 1.2],
        ["zoom"],
        1,
        10,
        6,
        13.5,
      ];
      const activeCircleBaseRadius = [
        "interpolate",
        ["exponential", 1.2],
        ["zoom"],
        1,
        10.4,
        3,
        13.4,
        6,
        17,
      ];
      let pulseFrame = null;
      let pulseStartedAt = 0;

      function startActivePulse() {
        if (pulseFrame !== null) return;
        pulseStartedAt = performance.now();

        const animate = (now) => {
          if (!map.getLayer("ny-route-point-active")) {
            pulseFrame = null;
            return;
          }

          const elapsed = (now - pulseStartedAt) / 1000;
          const wave = Math.sin(elapsed * Math.PI * 2 * 0.9);
          const radiusOffset = 1.4 + wave * 0.9;
          const opacity = 0.86 + ((wave + 1) * 0.07);

          map.setPaintProperty("ny-route-point-active", "circle-radius", [
            "+",
            activeCircleBaseRadius,
            radiusOffset,
          ]);
          map.setPaintProperty(
            "ny-route-point-active",
            "circle-opacity",
            opacity,
          );

          pulseFrame = requestAnimationFrame(animate);
        };

        pulseFrame = requestAnimationFrame(animate);
      }

      function stopActivePulse() {
        if (pulseFrame === null) return;
        cancelAnimationFrame(pulseFrame);
        pulseFrame = null;
      }

      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }

      function toRadians(value) {
        return (value * Math.PI) / 180;
      }

      function getDistanceKm(fromLng, fromLat, toLng, toLat) {
        const earthRadiusKm = 6371;
        const dLat = toRadians(toLat - fromLat);
        const dLng = toRadians(toLng - fromLng);
        const lat1 = toRadians(fromLat);
        const lat2 = toRadians(toLat);
        const sinLat = Math.sin(dLat / 2);
        const sinLng = Math.sin(dLng / 2);
        const a =
          sinLat * sinLat +
          Math.cos(lat1) * Math.cos(lat2) * sinLng * sinLng;
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return earthRadiusKm * c;
      }

      function getFlyDurationMs(targetLng, targetLat) {
        const center = map.getCenter();
        const distanceKm = getDistanceKm(center.lng, center.lat, targetLng, targetLat);
        const scaledDuration = Math.round(540 + Math.log1p(distanceKm) * 240);
        return clamp(scaledDuration, 650, 1750);
      }

      function getPopupContent(step, index) {
        const popupRoot = document.createElement("div");
        popupRoot.className = "ny-map-popup-card";

        if (step.heroImage) {
          const media = document.createElement("a");
          media.className = "ny-map-popup-card__media";
          media.href = step.url;

          const mediaImage = document.createElement("img");
          mediaImage.src = step.heroImage;
          mediaImage.alt =
            step.heroImageAlt || `${step.mapTitle || step.title} cover image`;
          mediaImage.loading = "lazy";
          mediaImage.decoding = "async";
          media.appendChild(mediaImage);
          popupRoot.appendChild(media);
        }

        const body = document.createElement("div");
        body.className = "ny-map-popup-card__body";

        const meta = document.createElement("p");
        meta.className = "ny-map-popup-card__meta";
        meta.textContent = `Stop ${step.mapOrder || index + 1}`;
        body.appendChild(meta);

        const popupTitle = document.createElement("a");
        popupTitle.className = "ny-map-popup-card__title";
        popupTitle.href = step.url;
        popupTitle.textContent = step.mapTitle || step.title;
        body.appendChild(popupTitle);

        const popupSubtitle = document.createElement("p");
        popupSubtitle.className = "ny-map-popup-card__subtitle";
        popupSubtitle.textContent = step.title;
        body.appendChild(popupSubtitle);

        popupRoot.appendChild(body);

        return popupRoot;
      }

      function setActive(index) {
        stepButtons.forEach((button, idx) => {
          button.classList.toggle("is-active", idx === index);
        });
        if (map.getLayer("ny-route-point-active")) {
          map.setFilter("ny-route-point-active", ["==", ["get", "index"], index]);
        }
      }

      function focusStep(index, options = {}) {
        const step = steps[index];
        if (!step) return;
        setActive(index);

        const targetZoom = step.transport === "flight"
          ? isCoarsePointer
            ? 3.2
            : 3.6
          : isCoarsePointer
            ? 5.2
            : 5.8;

        map.flyTo({
          center: [step.lng, step.lat],
          zoom: targetZoom,
          duration: prefersReducedMotion ? 0 : getFlyDurationMs(step.lng, step.lat),
          easing: (t) => 1 - Math.pow(1 - t, 3),
          essential: true,
        });

        if (options.openPopup) {
          popup
            .setLngLat([step.lng, step.lat])
            .setDOMContent(getPopupContent(step, index))
            .addTo(map);
        }

        if (options.scrollCard) {
          const button = stepButtons[index];
          if (button) button.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      }

      function fitRouteBounds() {
        if (bounds.isEmpty()) return;
        map.fitBounds(bounds, {
          padding: isCoarsePointer
            ? { top: 88, right: 48, bottom: 84, left: 48 }
            : { top: 100, right: 120, bottom: 100, left: 120 },
          duration: 0,
          maxZoom: 4.5,
        });
      }

      function getInitialMobileZoom(step) {
        if (!step) return 1.2;
        if (step.transport === "flight") return 1.05;
        return 1.3;
      }

      function showInitialViewport() {
        if (isCoarsePointer && steps.length > 0) {
          const firstStep = steps[0];
          map.jumpTo({
            center: [firstStep.lng, firstStep.lat],
            zoom: getInitialMobileZoom(firstStep),
            bearing: 0,
            pitch: 0,
          });
          return;
        }
        fitRouteBounds();
      }

      function nudgeCameraForInitialRender() {
        const center = map.getCenter();
        const zoom = map.getZoom();
        const bearing = map.getBearing();
        const pitch = map.getPitch();
        // Tiny center delta nudges the renderer without visible camera movement.
        const delta = 0.000001;
        map.jumpTo({ center: [center.lng + delta, center.lat], zoom, bearing, pitch });
        map.jumpTo({ center: [center.lng, center.lat], zoom, bearing, pitch });
      }

      map.on("load", () => {
        map.setFog({});

        map.addSource("ny-route-source", {
          type: "geojson",
          data: routeData,
        });
        if (traceData) {
          map.addSource("ny-route-trace-source", {
            type: "geojson",
            data: traceData,
          });
        }
        map.addSource("ny-route-points-source", {
          type: "geojson",
          data: stepPointData,
        });

        if (traceData) {
          map.addLayer({
            id: "ny-route-line-trace",
            type: "line",
            source: "ny-route-trace-source",
            layout: {
              "line-cap": "round",
              "line-join": "round",
            },
            paint: {
              "line-color": "#0ea5e9",
              "line-width": [
                "interpolate",
                ["linear"],
                ["zoom"],
                1,
                1.4,
                3,
                2.2,
                6,
                3,
              ],
              "line-opacity": 0.62,
            },
          });
        }

        map.addLayer({
          id: "ny-route-line-main",
          type: "line",
          source: "ny-route-source",
          layout: {
            "line-cap": "round",
            "line-join": "round",
          },
          paint: {
            "line-color": [
              "match",
              ["get", "transport"],
              "drive",
              "#2563eb",
              "boat",
              "#dc2626",
              "flight",
              "#f97316",
              "#0f172a",
            ],
            "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              1,
              1.5,
              3,
              2.75,
              6,
              4.25,
            ],
            "line-opacity": 0.88,
          },
        });

        map.addLayer({
          id: "ny-route-line-flight-dash",
          type: "line",
          source: "ny-route-source",
          filter: ["==", ["get", "transport"], "flight"],
          layout: {
            "line-cap": "round",
            "line-join": "round",
          },
          paint: {
            "line-color": "#fb923c",
            "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              1,
              1.5,
              3,
              2.75,
              6,
              4.25,
            ],
            "line-dasharray": [1.4, 1.2],
            "line-opacity": 0.95,
          },
        });

        map.addLayer({
          id: "ny-route-point-hitbox",
          type: "circle",
          source: "ny-route-points-source",
          paint: {
            "circle-color": "rgba(0, 0, 0, 0)",
            "circle-radius": [
              "interpolate",
              ["exponential", 1.2],
              ["zoom"],
              1,
              16,
              3,
              20,
              6,
              24,
            ],
            "circle-stroke-width": 0,
          },
        });

        map.addLayer({
          id: "ny-route-point-circles",
          type: "circle",
          source: "ny-route-points-source",
          paint: {
            "circle-color": [
              "match",
              ["get", "transport"],
              "drive",
              "#2563eb",
              "boat",
              "#dc2626",
              "flight",
              "#f97316",
              "#0f172a",
            ],
            "circle-radius": pointCircleRadius,
            "circle-stroke-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              1,
              1.6,
              6,
              2.4,
            ],
            "circle-stroke-color": "#ffffff",
            "circle-emissive-strength": 0.2,
          },
        });

        map.addLayer({
          id: "ny-route-point-labels",
          type: "symbol",
          source: "ny-route-points-source",
          layout: {
            "text-field": ["get", "markerLabel"],
            "text-size": pointLabelSize,
            "text-font": ["Open Sans Bold", "Arial Unicode MS Bold"],
          },
          paint: {
            "text-color": "#ffffff",
            "text-halo-color": "rgba(0, 0, 0, 0.18)",
            "text-halo-width": 1,
          },
        });

        map.addLayer({
          id: "ny-route-point-active",
          type: "circle",
          source: "ny-route-points-source",
          filter: ["==", ["get", "index"], -1],
          paint: {
            "circle-color": "rgba(255,255,255,0)",
            "circle-radius": activeCircleBaseRadius,
            "circle-stroke-width": 2.4,
            "circle-stroke-color": "#ffffff",
            "circle-opacity": 0.92,
          },
        });

        function bindPointLayerInteractions(layerId) {
          map.on("click", layerId, (event) => {
            const feature = event.features?.[0];
            if (!feature) return;
            const featureIndex = Number(feature.properties?.index ?? "-1");
            if (Number.isNaN(featureIndex) || featureIndex < 0) return;
            focusStep(featureIndex, { openPopup: true, scrollCard: true });
          });

          map.on("mouseenter", layerId, () => {
            map.getCanvas().style.cursor = "pointer";
          });
          map.on("mouseleave", layerId, () => {
            map.getCanvas().style.cursor = "";
          });
        }

        bindPointLayerInteractions("ny-route-point-hitbox");
        startActivePulse();

        map.on("click", (event) => {
          const hitFeatures = map.queryRenderedFeatures(event.point, {
            layers: ["ny-route-point-hitbox"],
          });
          if (hitFeatures.length === 0 && popup.isOpen()) {
            popup.remove();
          }
        });

        map.on("dragstart", () => {
          if (popup.isOpen()) popup.remove();
        });

        map.on("rotatestart", () => {
          if (popup.isOpen()) popup.remove();
        });

        const onEscape = (event) => {
          if (event.key !== "Escape") return;
          if (popup.isOpen()) popup.remove();
        };
        window.addEventListener("keydown", onEscape);
        map.on("remove", () => {
          window.removeEventListener("keydown", onEscape);
        });

        stepButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const index = Number(button.getAttribute("data-route-step") || "0");
            focusStep(index, { openPopup: true });
          });
        });

        let hasUserInteracted = false;
        const pendingRefreshTimers = [];
        const markUserInteraction = () => {
          hasUserInteracted = true;
          pendingRefreshTimers.forEach((id) => window.clearTimeout(id));
          pendingRefreshTimers.length = 0;
        };

        const kickstartInitialRender = () => {
          if (hasUserInteracted) return;
          map.resize();
          showInitialViewport();
          if (steps.length > 0) {
            setActive(0);
          }
          if (isCoarsePointer) {
            nudgeCameraForInitialRender();
          }
          map.triggerRepaint();
        };

        map.on("touchstart", markUserInteraction);
        map.on("mousedown", markUserInteraction);
        map.on("dragstart", markUserInteraction);
        map.on("movestart", markUserInteraction);
        map.on("remove", () => {
          pendingRefreshTimers.forEach((id) => window.clearTimeout(id));
        });

        requestAnimationFrame(() => {
          kickstartInitialRender();
          pendingRefreshTimers.push(
            window.setTimeout(kickstartInitialRender, 120),
            window.setTimeout(kickstartInitialRender, 420),
            window.setTimeout(kickstartInitialRender, 900),
          );
        });
      });

      map.on("remove", stopActivePulse);
    })();
  </script>

