            <Placemark>
                <name>07 BC old factory lot</name>                      
                <visibility>1</visibility>            
                <open>0</open>                        
                                                    
                <TimeStamp>
                    <when>2014-04-15T02:34:04Z</when>
                </TimeStamp> 
                                
                <description>
                     - Wild camp off the highway to Esfahan within an old factory lot protected by a fence (guard). We forgot to take pictures. 
                </description>       
                <LookAt>
                    <longitude>50.395584963262081</longitude>
                    <latitude>34.576222971081734</latitude>
                    <range>500</range>
                    <tilt>45</tilt>
