                <TimeStamp>
                    <when>2014-04-21T10:50:10Z</when>
                </TimeStamp> 
                                
                <description>
                     - Wild camp of the main road, quite on farmland.                </description>       
                <LookAt>
                    <longitude>59.7620780300349</longitude>
