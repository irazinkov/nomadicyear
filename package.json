{
  "name": "nomadic-year",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "phase0:url-inventory": "node scripts/phase0/capture-url-inventory.mjs",
    "phase0:redirect-draft": "node scripts/phase0/generate-redirect-draft.mjs",
    "phase2:analyze-wxr": "node scripts/migrate/analyze-wxr.mjs",
    "phase2:migrate-wxr": "node scripts/migrate/convert-wxr-to-markdown.mjs",
    "phase3:migrate-pages": "node scripts/migrate/convert-wxr-pages-to-markdown.mjs",
    "phase4:prepare-assets": "node scripts/phase4/prepare-new-uploads-and-audit.mjs",
    "phase4:fix-alt": "node scripts/phase4/fix-missing-alt-text.mjs",
    "phase4:sync-public": "node scripts/phase4/sync-referenced-assets-to-public.mjs",
    "phase4:sync-public:strict": "node scripts/phase4/sync-referenced-assets-to-public.mjs --fail-on-missing",
    "phase4:validate": "node scripts/phase4/validate-phase4.mjs",
    "phase4:validate:strict-alt": "node scripts/phase4/validate-phase4.mjs --fail-on-missing-alt",
    "phase4:measure": "node scripts/phase4/measure-build-metrics.mjs --fail-on-budget",
    "phase4:measure:skip-build": "node scripts/phase4/measure-build-metrics.mjs --skip-build",
    "phase5:redirects": "node scripts/phase5/generate-cloudflare-redirects.mjs",
    "phase5:audit": "node scripts/phase5/run-phase5-audit.mjs",
    "phase5:audit:strict": "node scripts/phase5/run-phase5-audit.mjs --fail-on-critical"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.8",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/parser": "^8.57.2",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^9.38.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
